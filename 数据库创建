create table activity
(
    mid        bigint unsigned auto_increment comment '活动ID'
        primary key,
    name       varchar(100) not null comment '活动名称',
    start_time datetime     not null comment '会议开始时间',
    end_time   datetime     not null comment '会议结束时间'
)
    comment '活动表';

create table activity_sign
(
    id            bigint unsigned auto_increment comment '活动签到记录ID'
        primary key,
    mid           bigint unsigned not null comment '活动ID',
    student_id    varchar(10)     not null comment '学号',
    name          varchar(10)     not null comment '姓名',
    sign_time     datetime        not null comment '签到时间',
    sign_out_time datetime        null comment '签退时间'
)
    comment '活动签到表';

create table sign
(
    sign_id       bigint unsigned auto_increment comment '记录ID'
        primary key,
    student_id    varchar(10)                        not null comment '学号',
    sign_time     datetime default CURRENT_TIMESTAMP null comment '签到时间',
    sign_out_time datetime                           null comment '签退时间',
    status        tinyint  default 0                 not null comment '0：未签到 1：已签到',
    student_name  varchar(50)                        not null comment '签到时的姓名快照',
    constraint uk_student_time
        unique (student_id, sign_time, sign_out_time)
)
    comment '签到记录表';

create table student
(
    student_id   varchar(10)                        not null comment '学号'
        primary key,
    name         varchar(10)                        not null comment '姓名',
    created_time datetime default CURRENT_TIMESTAMP null comment '创建时间'
)
    comment '用户表';

